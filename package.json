    "gulp-csso": "~4.0.1",
    "gulp-eslint": "~6.0.0",
    "gulp-imagemin": "~9.2.0",
    "gulp-istanbul": "~1.1.1",
    "gulp-less": "~5.0.0",
    "gulp-load-plugins": "~2.0.8",
    "gulp-mocha": "~10.0.1",
    "gulp-ng-annotate": "~2.1.0",
    "gulp-nodemon": "~2.5.0",
    "gulp-protractor": "~4.1.1",
    "gulp-refresh": "~1.1.0",
    "gulp-rename": "~2.1.0",
    "gulp-rev": "^12.0.0",
    "gulp-sass": "~6.0.1",
    "gulp-uglify": "~3.0.2",
    "gulp-util": "~3.0.7",
    "imagemin-pngquant": "~10.0.0",
    "istanbul": "~0.4.2",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-firefox-launcher": "~2.1.3",
