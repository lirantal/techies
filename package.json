    "passport-twitter": "~1.0.4",
    "phantomjs-prebuilt": "~2.1.4",
    "serve-favicon": "~2.3.0",
    "socket.io": "^1.4.8",
    "validator": "~6.0.0",
    "winston": "^2.2.0",
    "wiredep": "~4.0.0"
  },
  "devDependencies": {
    "coveralls": "~3.1.1",
    "del": "^8.0.1",
    "eslint": "~10.5.0",
    "eslint-config-airbnb": "~19.0.4",
    "gulp": "~5.0.1",
    "gulp-angular-templatecache": "~3.0.1",
    "gulp-autoprefixer": "~10.0.0",
    "gulp-concat": "~2.6.0",
