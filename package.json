    "supertest": "~7.2.2",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "markdownlint-cli": "0.49.0"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  }
}
